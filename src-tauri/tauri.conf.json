{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Diablo II Ultra Utility",
  "version": "2.3.0",
  "identifier": "com.d2r-ultra-utility.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Diablo II Ultra Utility",
        "width": 600,
        "height": 751,
        "decorations": false,
        "resizable": true,
        "minimizable": true,
        "maximizable": true,
        "closable": true,
        "center": true
      },
      {
        "label": "overlay",
        "title": "Run Counter — Add Loot",
        "maximizable": false,
        "width": 460,
        "height": 300,
        "visible": false,
        "alwaysOnTop": true,
        "decorations": false,
        "skipTaskbar": true,
        "transparent": true,
        "resizable": false,
        "shadow": false,
        "center": true
      },
      {
        "label": "display",
        "title": "Run Counter — Display",
        "maximizable": false,
        "width": 340,
        "height": 240,
        "minWidth": 200,
        "minHeight": 120,
        "visible": false,
        "alwaysOnTop": true,
        "decorations": false,
        "skipTaskbar": true,
        "transparent": true,
        "resizable": true,
        "shadow": false,
        "center": true
      },
      {
        "label": "session",
        "title": "Run Counter — New Session",
        "maximizable": false,
        "width": 480,
        "height": 340,
        "visible": false,
        "alwaysOnTop": true,
        "decorations": false,
        "skipTaskbar": true,
        "transparent": true,
        "resizable": false,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/TrayHard/d2r-ultra-utility/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ3ODUyQjZFNEM0OTMwMEMKUldRTU1FbE1iaXVGUi9DNk9ROWY1dWtFd0paUndVWXVRMHk0bnhqV21idU0vN0ZEU1pPM2daYmoK"
    }
  }
}
